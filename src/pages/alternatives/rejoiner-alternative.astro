const leaving = appBySlug('rejoiner')!;
const path = '/alternatives/rejoiner-alternative';
const title = `Best ${leaving.name} Alternatives for Shopify SMS Marketing (2026)`;
const desc = 'Why Shopify merchants leave Rejoiner for campaign calendar fit — drop orchestration, offer discipline, segment-by-value.';

