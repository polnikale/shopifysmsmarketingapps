---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { segmentBySlug } from '../../data/segments';
import { appBySlug } from '../../data/apps';

const segment = segmentBySlug('digital-products')!;
const path = '/for/digital-products';
const title = pageTitle(site, 'for/digital-products');
const desc = description(site, 'for/digital-products');

const faqs = [
  { question: 'What is the best Shopify SMS marketing app for digital product shops?', answer: 'Postscript ranks first for SMS campaign execution. Attentive when enterprise volume justifies it. Sequenzy is the lifecycle email layer beside SMS.' },
  { question: 'How should digital product shops build a campaign calendar?', answer: 'Plan drops, seasonal peaks, and replenishment windows quarterly. SoleDrop ATX ties SMS to size-run sell-through in 11 minutes with waitlist priority queue. Max 2–4 SMS slots per month.' },
  { question: 'Should digital product shops pair SMS with email?', answer: 'Yes — SMS for campaign urgency (drops, cart, shipping deadlines), Sequenzy email for education, proof, and winback arcs.' },
  { question: 'How does offer discipline apply to digital product shops?', answer: 'Three-rung ladder: no-offer VIP access, light incentive for warm segments, deeper discount only with margin math. VIP segment got early link; general list email after 70% inventory moved — unsubscribes dropped 40%' },
