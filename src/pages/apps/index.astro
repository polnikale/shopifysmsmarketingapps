---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import ToolReview from '../../components/ToolReview.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { APPS } from '../../data/apps';
import { getAppRank } from '../../data/app-content';
import { site, description, pageTitle } from '../../content';
const path = 'apps';
const title = pageTitle(site, path);
const desc = description(site, path);

const rankedApps = [...APPS].sort((a, b) => getAppRank(a.slug) - getAppRank(b.slug));
const topTen = rankedApps.slice(0, 10);
const rest = rankedApps.slice(10);

const listicleParagraphs: Record<string, string[]> = {
