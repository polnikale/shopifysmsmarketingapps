---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPS, SEGMENTS, USE_CASES, description, pageTitle, siteFromHost } from '../content';
const site = siteFromHost();
const path = '';
const title = pageTitle(site, path);
const desc = description(site, path);
const recommended = APPS.filter(a => a.channels.includes(site.channel) || a.channels.includes('marketing')).slice(0,10);
---
<BaseLayout title={title} description={desc} site={site} path="/">
  <section class="relative overflow-hidden border-b border-emerald-900/10 bg-[radial-gradient(circle_at_top_left,#d9f99d,transparent_30%),linear-gradient(135deg,#f7faf5,#ecfdf5_45%,#ffffff)] py-16 md:py-24">
    <div class="container grid gap-10 lg:grid-cols-[1.15fr_.85fr] lg:items-center">
      <div>
        <span class="badge">Updated for Shopify stores in 2026</span>
        <h1 class="hero-title mt-5">Best {site.primaryKeyword} for stores that care about repeat revenue</h1>
        <p class="mt-6 max-w-2xl text-xl text-slate-700">{site.heroPromise} {site.intro}</p>
        <div class="mt-8 flex flex-wrap gap-3"><a class="btn btn-primary" href="/apps">Compare apps</a><a class="btn btn-secondary" href="/use-cases/abandoned-cart">Start with cart recovery</a></div>
      </div>
      <div class="card bg-white/80">
        <div class="text-sm font-bold uppercase tracking-wide text-emerald-700">Quick verdict</div>
        <h2 class="mt-3 text-3xl font-bold text-slate-950">Shopify-native beats generic automation.</h2>
        <p class="mt-4 text-slate-700">The best {site.keywordPlural} understand customers, products, orders, discount codes, inventory, checkout events, consent, and repeat purchase timing. {site.bestOverallReason}</p>
        <ul class="mt-6 space-y-3 text-sm text-slate-700">
          <li>✓ Built around Shopify customer and order data</li><li>✓ Includes lifecycle, cart recovery, and post-purchase flows</li><li>✓ Prioritizes revenue quality over vanity open rates</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="container py-14">
    <div class="mb-8 flex items-end justify-between gap-6"><div><span class="badge">Ranked shortlist</span><h2 class="mt-3 text-3xl font-bold">Top {site.shortName.toLowerCase()} to evaluate first</h2></div><a class="link" href="/apps">View all apps →</a></div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{recommended.map((app, i) => <a class="card hover:-translate-y-1 transition" href={`/apps/${app.slug}`}><div class="text-sm font-bold text-emerald-700">#{i+1}</div><h3 class="mt-2 text-xl font-bold text-slate-950">{app.name}</h3><p class="mt-2 text-sm text-slate-600">{app.bestFor}</p><p class="mt-4 text-sm font-semibold text-slate-900">{app.pricing}</p></a>)}</div>
  </section>
  <section class="bg-white py-14"><div class="container grid gap-8 md:grid-cols-3"><div class="md:col-span-1"><span class="badge">SEO map</span><h2 class="mt-3 text-3xl font-bold">100+ unique pages per domain</h2><p class="mt-4 text-slate-600">Each domain renders its own titles, intros, recommendations, internal links, and Shopify-specific copy for the exact keyword family.</p></div><div class="grid gap-4 md:col-span-2 sm:grid-cols-2">{USE_CASES.slice(0,8).map(u=><a class="card" href={`/use-cases/${u.slug}`}><h3 class="font-bold text-slate-950">{u.name}</h3><p class="mt-2 text-sm text-slate-600">{u.job}</p></a>)}</div></div></section>
  <section class="container py-14"><h2 class="text-3xl font-bold">Popular store-type guides</h2><div class="mt-6 grid gap-4 md:grid-cols-3">{SEGMENTS.slice(0,9).map(s=><a class="card" href={`/for/${s.slug}`}><h3 class="font-bold">{s.name}</h3><p class="mt-2 text-sm text-slate-600">Handles {s.pain}.</p></a>)}</div></section>
</BaseLayout>
