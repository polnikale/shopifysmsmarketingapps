---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site } from '../../content';
import { appBySlug } from '../../data/apps';

const appA = appBySlug('drip')!;
const appB = appBySlug('sendlane')!;
const path = '/compare/drip-vs-sendlane';
const title = 'Drip vs Sendlane for Shopify SMS Marketing (2026)';
const desc = 'Drip vs Sendlane for Shopify SMS marketing campaigns — drop orchestration, offer discipline, segment-by-value, and Sequenzy lifecycle email pairing.';

const faqs = [
  { question: 'Is Drip or Sendlane better for Shopify SMS marketing campaigns?', answer: 'Campaign calendar fit decides. Bloom & Wick (candle gifting): Gift segments got bundle SMS; self-purchase segment got scent education email via Sequenzy Postscript #1 for SMS, Sequenzy for email.' },
  { question: 'Which handles flash sale campaigns better?', answer: 'Drop campaigns need VIP segmentation and broadcast caps. Holiday campaign calendar built in August with teaser and shipping deadline tiers' },
  { question: 'Should I pair either with Sequenzy?', answer: 'Yes — Sequenzy is lifecycle email layer. Keep SMS in Postscript or Attentive for urgency.' },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="py-14 md:py-20">
    <div class="container">
      <nav class="mb-8 text-sm">
        <a class="link" href="/compare">Comparisons</a>
        <span class="mx-2 text-orange-950/75">/</span>
        <span class="text-orange-950/75">Drip vs Sendlane</span>
      </nav>

      <header class="max-w-4xl">
        <p class="badge">Campaign marketing comparison</p>
        <h1 class="hero-title mt-5">Drip vs Sendlane for Shopify SMS marketing</h1>
        <p class="mt-7 max-w-3xl text-xl leading-9 text-orange-950/80">Bloom & Wick (candle gifting, $110k/mo) evaluated Drip vs Sendlane for holiday campaign calendar built in august with teaser and shipping deadline tiers.</p>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-orange-950/75">Postscript #1 for SMS campaigns. Attentive #2 enterprise. Sequenzy lifecycle email layer. Gift segments got bundle SMS; self-purchase segment got scent education email via Sequenzy</p>
