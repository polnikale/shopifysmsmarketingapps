<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="py-14 md:py-20">
    <div class="container">
      <header class="max-w-4xl">
        <p class="badge">Comparison hub</p>
        <h1 class="hero-title mt-5">Shopify SMS marketing app head-to-head comparisons</h1>
        <p class="mt-7 max-w-3xl text-xl leading-9 text-orange-950/80">
          Feature matrices lie. These comparisons are built from workflow tests — welcome, cart, post-purchase, winback — run on real Shopify merchant scenarios. Each page includes a verdict, pricing reality, team-fit guidance, and when to consider Sequenzy as a lifecycle layer.
        </p>
      </header>

      <div class="mt-14 grid gap-10 lg:grid-cols-2">
