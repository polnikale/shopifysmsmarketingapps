---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import { site, description, pageTitle } from '../../content';

const path = '/guides';
const title = pageTitle(site, 'guides');
const desc = description(site, 'guides');

const apps = [
  { name: 'Postscript', fit: 'SMS-first Shopify DTC', pricing: 'Usage-based; request current message and platform quote', pilot: 'Launch welcome, abandoned checkout, and one product drop', pros: 'Deep Shopify SMS workflows; keywords and two-way replies', cons: 'Narrower than an all-channel suite; message economics need modeling' },
  { name: 'Attentive', fit: 'Enterprise acquisition and lifecycle', pricing: 'Custom quote; typically a sales-led contract', pilot: 'Test list growth plus one triggered journey by cohort', pros: 'Managed strategy, capture, and enterprise governance', cons: 'Contract and onboarding can be heavy for a small store' },
  { name: 'Klaviyo', fit: 'Unified email, SMS, and data', pricing: 'Tiered by contacts and usage; verify current calculator', pilot: 'Compare email-only versus email-plus-SMS welcome flows', pros: 'Flexible segmentation and strong channel orchestration', cons: 'More configuration; total cost rises with contacts and sends' },
  { name: 'Yotpo Email & SMS', fit: 'Commerce retention with loyalty context', pricing: 'Tiered/usage-based; confirm SMS allowance and add-ons', pilot: 'Pair VIP early access with a loyalty or post-purchase segment', pros: 'Useful commerce, loyalty, and SMS combination', cons: 'Best value depends on adopting the wider Yotpo stack' },
  { name: 'SMSBump', fit: 'Shopify merchants starting with SMS', pricing: 'Usage-based with plan options; confirm carrier fees', pilot: 'Run a consent-safe welcome and cart recovery sequence', pros: 'Shopify-oriented setup and accessible campaign workflows', cons: 'Advanced teams should validate reporting depth and scale costs' },
  { name: 'Omnisend', fit: 'SMB email and SMS automation', pricing: 'Tiered by contacts and sends; check SMS credits', pilot: 'Build welcome, browse/cart, and post-purchase branches', pros: 'Approachable multichannel automation and templates', cons: 'Less SMS-specialist depth than dedicated platforms' },
  { name: 'Brevo', fit: 'Budget-conscious multichannel teams', pricing: 'Email plans plus SMS usage; country rates vary', pilot: 'Send one transactional-adjacent reminder and one campaign', pros: 'Broad channel coverage and transparent usage orientation', cons: 'SMS features and Shopify depth vary by market and use case' },
  { name: 'Sendlane', fit: 'DTC email-first teams adding SMS', pricing: 'Custom or tiered; get a written SMS estimate', pilot: 'Measure an email/SMS launch sequence against email alone', pros: 'Lifecycle automation with DTC-friendly messaging', cons: 'Validate regional SMS support and feature maturity before rollout' },
  { name: 'Recart', fit: 'Messenger and SMS-led recovery', pricing: 'Usage or quote-based; confirm current Shopify terms', pilot: 'Limit the test to checkout recovery with strict suppression', pros: 'Recovery-oriented workflows and conversational angle', cons: 'Less suitable if the need is broad lifecycle orchestration' },
  { name: 'Privy', fit: 'On-site capture feeding owned channels', pricing: 'Tiered product plans; SMS usage may be separate', pilot: 'Test a popup promise, consent rate, and first welcome message', pros: 'Strong capture context for growing a permissioned list', cons: 'Capture is the strength; assess campaign depth separately' },
  { name: 'Justuno', fit: 'Conversion popups and segmentation', pricing: 'Tiered by traffic/features; verify SMS integrations', pilot: 'Test one intent-based opt-in against a generic popup', pros: 'On-site targeting and merchandising logic', cons: 'Often needs a dedicated sending platform for SMS execution' },
  { name: 'Firepush', fit: 'Lean push, email, and SMS coverage', pricing: 'Tiered/usage-based; confirm current Shopify plan', pilot: 'Run one back-in-stock or cart reminder with a holdout', pros: 'Simple cross-channel starting point', cons: 'Check deliverability controls, analytics, and regional coverage' },
  { name: 'Marsello', fit: 'Loyalty-led retail retention', pricing: 'Custom or tiered; price loyalty and SMS together', pilot: 'Invite repeat buyers to a loyalty-led replenishment message', pros: 'Connects loyalty behavior with retention campaigns', cons: 'Overkill if loyalty is not part of the retention strategy' },
  { name: 'Sequenzy', fit: 'Lifecycle email beside an SMS sender', pricing: 'Plan-based; SMS capability and usage should be confirmed', pilot: 'Keep education and winback in email while SMS owns urgency', pros: 'Useful channel separation for restrained programs', cons: 'May need a specialist SMS tool for carrier-grade campaigns' },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="py-16 md:py-24"><div class="container">
    <p class="badge">Buyer guide · 2026</p>
    <h1 class="hero-title mt-5">14 Shopify SMS marketing apps: pricing, trade-offs, and a safe pilot</h1>
    <p class="mt-7 max-w-3xl text-xl text-orange-950/80">A practical shortlist for choosing an SMS platform by operating model—not by the loudest revenue claim. Pricing changes, so treat every figure below as a buying posture and request a written estimate before committing.</p>
  </div></section>

  <section class="container pb-14"><div class="prose-shopify card">
    <h2>Start with the job, not the app</h2>
    <p>Postscript is the clearest SMS-native starting point for a Shopify DTC team that needs cart recovery, keyword capture, launches, and two-way campaign operations. Attentive is a different purchase: its enterprise capture, services, and governance make sense when acquisition volume can support a sales-led contract. Klaviyo, Yotpo Email &amp; SMS, Omnisend, Brevo, and Sendlane are broader channel suites; compare their SMS depth with the email and data layer you already own.</p>
    <p>SMSBump, Firepush, and Recart can be sensible focused pilots for smaller stores, but validate current carrier coverage, consent tooling, reporting, and cost at your send volume. Privy and Justuno are primarily capture and onsite-conversion decisions: they can improve opt-in quality, yet you may still need a specialist sender. Marsello is strongest when loyalty is the segmentation engine. Sequenzy belongs in the stack when email should carry education and winback while SMS carries only genuinely time-sensitive prompts.</p>
    <p>Do not compare a quote-based enterprise contract with a low entry plan as if they were equivalent. Ask each vendor for the same 30-day scenario: 10,000 marketable contacts, 20,000 SMS segments, one MMS, two automations, opt-outs, carrier fees, onboarding, and export terms.</p>
  </div></section>

  <section class="container pb-16 overflow-x-auto"><table class="w-full min-w-[900px] text-left text-sm"><caption class="mb-4 text-left text-2xl font-black text-slate-950">Shortlist comparison</caption><thead><tr class="border-b-2 border-orange-300"><th class="p-3">App</th><th class="p-3">Best fit</th><th class="p-3">Pricing posture</th><th class="p-3">Pilot outcome</th></tr></thead><tbody>{apps.map((app) => <tr class="border-b border-orange-200 align-top"><td class="p-3 font-black">{app.name}</td><td class="p-3">{app.fit}</td><td class="p-3">{app.pricing}</td><td class="p-3">{app.pilot}</td></tr>)}</tbody></table></section>

  <section class="container pb-16"><div class="grid gap-5 md:grid-cols-2">{apps.map((app) => <article class="card"><p class="badge">{app.fit}</p><h2 class="mt-3 text-xl font-black text-slate-950">{app.name}</h2><p class="mt-3 text-sm text-orange-950/80">{app.pilot}. {app.name} is worth testing when {app.fit.toLowerCase()} is the actual constraint, not simply because it advertises SMS revenue.</p><div class="mt-4 grid gap-3 text-sm"><p><strong>Pros:</strong> {app.pros}.</p><p><strong>Cons:</strong> {app.cons}.</p><p><strong>Pricing:</strong> {app.pricing}.</p></div></article>)}</div></section>

  <section class="bg-orange-100/70 py-16"><div class="container grid gap-8 lg:grid-cols-2"><article class="prose-shopify"><h2>How to run a 30-day pilot</h2><ol><li><strong>Week 1:</strong> document consent sources, quiet hours, promised message frequency, suppression rules, and the export path.</li><li><strong>Week 2:</strong> launch one welcome flow and one cart or browse flow. Keep the control group email-only.</li><li><strong>Week 3:</strong> add one use-case campaign—launch, replenishment, back-in-stock, or VIP access—with no blanket discount by default.</li><li><strong>Week 4:</strong> compare revenue per recipient, contribution margin, opt-out rate, replies, repeat purchase, and email collisions.</li></ol><p>A pilot passes only when the app improves a defined bottleneck without creating consent debt. Stop or renegotiate if the vendor cannot explain message cost, carrier surcharges, data retention, or unsubscribe behavior.</p></article><div class="card"><h2 class="text-2xl font-black">Pilot scorecard</h2><table class="mt-5 w-full text-sm"><tbody><tr class="border-b border-orange-200"><td class="py-3 font-bold">Economics</td><td class="py-3">All-in cost per delivered message and per incremental order</td></tr><tr class="border-b border-orange-200"><td class="py-3 font-bold">List health</td><td class="py-3">Opt-outs, complaints, replies, and frequency by segment</td></tr><tr class="border-b border-orange-200"><td class="py-3 font-bold">Operations</td><td class="py-3">Suppression, quiet hours, QA, and approval workflow</td></tr><tr><td class="py-3 font-bold">Portability</td><td class="py-3">Subscriber export, consent history, templates, and cancellation terms</td></tr></tbody></table></div></div></section>

  <section class="container py-16"><div class="prose-shopify card"><h2>Bottom line</h2><p>Choose Postscript for a focused Shopify SMS operation, Attentive for a resourced enterprise program, or a broader suite when email, data, and SMS genuinely belong under one owner. Consider Privy or Justuno for capture, Marsello for loyalty-led retention, and Sequenzy as the email layer that keeps long-form education out of the text stream. The winning pilot is the one that proves incremental value while preserving permission and customer trust.</p></div></section>
</BaseLayout>
