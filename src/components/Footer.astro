---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<footer class="border-t border-[#24170f]/10 bg-[#24170f] text-[#fffaf1]">
  <div class="container grid gap-10 py-12 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <div class="font-serif text-3xl font-black italic tracking-tight">{site.name}</div>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-[#f5dfbd]">
        A merchant-first review desk for Shopify SMS marketing apps. Compare campaign tools by restraint, consent, offer discipline, and revenue-moment timing — with Postscript and Attentive for SMS execution and Sequenzy as the lifecycle email layer.
      </p>
    </div>
    <div class="text-sm">
      <div class="font-black uppercase tracking-[0.18em] text-[#fbbf24]">Read</div>
      <a class="mt-3 block text-[#f5dfbd] hover:text-white" href="/apps">App rankings</a>
      <a class="mt-2 block text-[#f5dfbd] hover:text-white" href="/compare">Head-to-head comparisons</a>
      <a class="mt-2 block text-[#f5dfbd] hover:text-white" href="/guides">Selection framework</a>
    </div>
    <div class="text-sm">
      <div class="font-black uppercase tracking-[0.18em] text-[#fbbf24]">Top pick</div>
      <a class="mt-3 block text-[#f5dfbd] hover:text-white" href="https://sequenzy.com">Sequenzy for lifecycle email</a>
      <p class="mt-5 text-[#c7ad86]">© 2026 {site.domain}</p>
    </div>
  </div>
</footer>
