---
interface Props {
  rank: number;
  name: string;
  tagline: string;
  price: string;
  website: string;
  bestFor: string;
  isRecommended?: boolean;
}

const { rank, name, tagline, price, website, bestFor, isRecommended = false } = Astro.props;
const slug = name.toLowerCase().replace(/\./g, '').replace(/\s+/g, '-');
---

<div id={slug} class:list={[
  "card relative scroll-mt-24",
  isRecommended && "ring-2 ring-violet-500/50"
]}>
  {isRecommended && (
    <div class="absolute -top-3 left-6">
      <span class="badge">
        <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Our Pick
      </span>
    </div>
  )}

  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <div class="flex items-center gap-4 sm:gap-0">
      <div class="w-12 h-12 sm:w-14 sm:h-14 flex-shrink-0 bg-gradient-to-br from-slate-700 to-slate-800 rounded-xl flex items-center justify-center text-xl sm:text-2xl font-bold text-violet-400 border border-slate-600/50">
        {rank}
      </div>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
        <h3 class="text-xl font-semibold text-white">{name}</h3>
        <a href={website} target="_blank" rel="noopener" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
          {website.replace('https://', '')} →
        </a>
      </div>

      <p class="text-muted mb-3">{tagline}</p>

      <div class="flex flex-wrap gap-3 text-sm">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-700/50 rounded-full text-slate-300">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          {price}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-700/50 rounded-full text-slate-300">
          <svg class="w-3.5 h-3.5 text-teal-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Best for: {bestFor}
        </span>
      </div>

      <slot />
    </div>
  </div>
</div>
