---
import type { ShopifyApp } from '../data/apps';
export interface Props {
  app: ShopifyApp;
  rank: number;
  badge?: string;
  paragraphs: string[];
}
const { app, rank, badge, paragraphs } = Astro.props;
---
<section class="card" id={app.slug}>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="flex items-center gap-4">
      <span class="rank-pill">{rank}</span>
      <div>
        {badge && <span class="badge mb-2">{badge}</span>}
        <h2 class="font-serif text-3xl font-black tracking-tight text-[#24170f]">{app.name}</h2>
        <p class="mt-2 text-lg font-bold text-[#5d3a1d]">{app.tagline}</p>
      </div>
    </div>
    <div class="text-right">
      <div class="text-2xl font-black text-[#9a5b16]">{app.pricing}</div>
      <div class="text-sm text-[#5d3a1d]">{app.priceDetail}</div>
      <div class="mt-1 text-sm font-black text-[#24170f]">★ {app.rating}</div>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-3 text-sm">
    <div><span class="font-black text-[#24170f]">Category</span><p class="text-[#5d3a1d]">{app.category}</p></div>
    <div><span class="font-black text-[#24170f]">Shopify depth</span><p class="text-[#5d3a1d]">{app.shopifyDepth}</p></div>
    <div><span class="font-black text-[#24170f]">Automation</span><p class="text-[#5d3a1d]">{app.automationDepth}</p></div>
  </div>

  <div class="prose-shopify mt-6">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>

  <div class="mt-8 grid gap-6 md:grid-cols-2">
    <div>
      <h3 class="text-sm font-black uppercase tracking-[0.16em] text-[#9a5b16]">Key strengths</h3>
      <ul class="mt-3 space-y-2 text-[16px] leading-7 text-[#4a2d17]">
        {app.strengths.map((s) => <li class="flex gap-2"><span class="text-[#9a5b16]">✓</span>{s}</li>)}
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-black uppercase tracking-[0.16em] text-[#9a5b16]">Limitations</h3>
      <ul class="mt-3 space-y-2 text-[16px] leading-7 text-[#4a2d17]">
        {app.limits.map((l) => <li class="flex gap-2"><span class="text-[#9a5b16]">–</span>{l}</li>)}
      </ul>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {app.features.map((f) => (
      <span class="rounded-full border border-[#24170f]/15 bg-[#fffaf1] px-3 py-1 text-xs font-bold text-[#5d3a1d]">{f}</span>
    ))}
  </div>

  <p class="mt-6 text-sm">
    <a class="link" href={`/apps/${app.slug}`}>Full {app.name} review →</a>
  </p>
</section>
